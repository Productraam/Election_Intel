# ── Election Intelligence environment ──
# Copy to `.env` and edit. Loaded by docker-compose; for bare-metal
# deployments either `export` these or use a process manager.

# Required: change in production!
EI_SECRET_KEY=change-me-to-a-long-random-string

# Server bind (only used by `python app.py`; gunicorn binds via -b flag)
EI_HOST=0.0.0.0
EI_PORT=5001
EI_DEBUG=0

# Database. Default = SQLite file `election_intel.db` next to app.py.
# For Postgres: postgresql://user:pass@host:5432/dbname
# DATABASE_URL=sqlite:///election_intel.db

# Default admin (created on first boot if no users exist)
# Change immediately after first login!
# (Hard-coded as admin / admin123 in database._seed_admin)

# WhatsApp provider configuration (optional)
# WHATSAPP_PROVIDER=meta            # meta | twilio | mock
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_ID=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
